# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control

# Flask session secret key (generate a strong random string)
FLASK_SECRET_KEY=your-strong-random-secret-key-here

# AES-256 encryption key — must be EXACTLY 32 characters
AES_SECRET_KEY=MedicalAISecureK3y_32BytesLong!!
